{
  "name": "super-productivity-cli",
  "version": "1.2.6",
  "description": "CLI for Super Productivity - Access your tasks from the command line",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "super-productivity",
    "cli",
    "task-manager",
    "productivity",
    "dropbox",
    "time-tracking"
  ],
  "author": "Onur Enes Şavat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onesvat/super-productivity-cli.git"
  },
  "homepage": "https://github.com/onesvat/super-productivity-cli#readme",
  "bugs": {
    "url": "https://github.com/onesvat/super-productivity-cli/issues"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@noble/ciphers": "^2.1.1",
    "commander": "^14.0.3",
    "hash-wasm": "^4.12.0"
  }
}
